// apps/api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ─── USERS & ROLES ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  role          String    @default("STUDENT")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  student       Student?
  faculty       Faculty?
  parent        Parent?
  superAdmin    SuperAdmin?

  @@map("users")
}



model Student {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name            String
  rollNumber      String?
  avatarUrl       String?
  avatarConfig    String?   // 3D avatar customization JSON
  
  schoolId        String
  school          School    @relation(fields: [schoolId], references: [id])
  classroomId     String?
  classroom       Classroom? @relation(fields: [classroomId], references: [id])
  
  // Gamification
  totalXP         Int       @default(0)
  level           Int       @default(1)
  coins           Int       @default(0)      // In-game currency ₹ (virtual)
  streak          Int       @default(0)      // Daily login streak
  lastActiveAt    DateTime?
  
  // Progress
  gameProgress    GameProgress[]
  achievements    StudentAchievement[]
  transactions    CoinTransaction[]
  quizAttempts    QuizAttempt[]
  
  // Relations
  parentLinks     StudentParentLink[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("students")
}

model Faculty {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id])
  
  classrooms  Classroom[]
  assignments Assignment[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("faculty")
}

model Parent {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  phone       String?
  
  // Notification settings (JSON string)
  notificationSettings String? @default("{}")
  
  children    StudentParentLink[]
  notifications ParentNotification[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("parents")
}

model SuperAdmin {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("super_admins")
}

model StudentParentLink {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parentId    String
  parent      Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  
  @@unique([studentId, parentId])
  @@map("student_parent_links")
}

// ─── SCHOOLS & CLASSROOMS ────────────────────────────────────

model School {
  id                String    @id @default(cuid())
  name              String
  city              String
  state             String
  boardType         String    @default("CBSE")   // CBSE, ICSE, State Board
  inviteCode        String?   @unique   // Auto-generated code for faculty/student registration
  curriculumVersion String    @default("grade-7")  // "grade-7", "grade-8", "grade-9"
  subscriptionTier  String    @default("free")     // "free" | "premium"
  
  students    Student[]
  faculty     Faculty[]
  classrooms  Classroom[]
  announcements Announcement[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("schools")
}

model Classroom {
  id          String    @id @default(cuid())
  name        String    // "7-A", "Grade 7 Section B"
  grade       Int       @default(7)
  section     String?
  
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id])
  facultyId   String?
  faculty     Faculty?  @relation(fields: [facultyId], references: [id])
  
  students    Student[]
  assignments Assignment[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("classrooms")
}

// ─── GAMES & PROGRESS ────────────────────────────────────────

model Game {
  id            String        @id @default(cuid())
  slug          String        @unique  // "problem-hunt" | "startup-simulator"
  name          String
  description   String
  thumbnailUrl  String?
  totalChapters Int
  isActive      Boolean       @default(true)
  
  chapters      Chapter[]
  progress      GameProgress[]
  
  @@map("games")
}

model Chapter {
  id              String    @id @default(cuid())
  gameId          String
  game            Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  
  number          Int
  slug            String
  title           String
  description     String
  curriculumRef   String?   // "Chapter 3: Finding Problems Around You"
  
  xpReward        Int       @default(100)
  coinReward      Int       @default(50)
  unlockCondition String?   // { requiredChapter: 2, requiredXP: 200 }
  
  levels          Level[]
  
  @@unique([gameId, number])
  @@map("chapters")
}

model Level {
  id            String    @id @default(cuid())
  chapterId     String
  chapter       Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  
  number        Int
  title         String
  type          String
  config        String    // Level-specific configuration (varies by type)
  maxScore      Int       @default(1000)
  passingScore  Int       @default(600)
  timeLimit     Int?      // seconds, null = no limit
  
  @@unique([chapterId, number])
  @@map("levels")
}



model GameProgress {
  id              String    @id @default(cuid())
  studentId       String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  gameId          String
  game            Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  
  currentChapter  Int       @default(1)
  currentLevel    Int       @default(1)
  status          String         @default("NOT_STARTED")
  
  totalScore      Int       @default(0)
  totalXPEarned   Int       @default(0)
  completedAt     DateTime?
  
  // Game-specific saved state
  detectiveSave   String?   // Problem Hunt save data
  simulatorSave   String?   // Startup Simulator save data
  
  levelAttempts   LevelAttempt[]
  
  @@unique([studentId, gameId])
  @@map("game_progress")
}



model LevelAttempt {
  id              String    @id @default(cuid())
  progressId      String
  progress        GameProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)
  
  chapterNumber   Int
  levelNumber     Int
  
  score           Int       @default(0)
  maxScore        Int
  passed          Boolean   @default(false)
  timeSpent       Int       @default(0)  // seconds
  
  choices         String?   // Record of choices made
  aiHintsUsed     Int       @default(0)
  
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  
  @@map("level_attempts")
}

// ─── GAMIFICATION ────────────────────────────────────────────

model Achievement {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String
  iconUrl     String?
  badgeColor  String    @default("#FFD700")
  xpBonus     Int       @default(0)
  rarity      String            @default("COMMON")
  
  condition   String    // Trigger condition JSON
  
  students    StudentAchievement[]
  
  @@map("achievements")
}



model StudentAchievement {
  id              String    @id @default(cuid())
  studentId       String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  achievementId   String
  achievement     Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  
  earnedAt        DateTime  @default(now())
  
  @@unique([studentId, achievementId])
  @@map("student_achievements")
}

model CoinTransaction {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  amount      Int       // positive = earned, negative = spent
  reason      String
  reference   String?   // levelAttemptId, achievementId, etc.
  
  createdAt   DateTime  @default(now())
  
  @@map("coin_transactions")
}

model Leaderboard {
  id          String    @id @default(cuid())
  type        String
  scopeId     String    // classroomId, schoolId, or "global"
  period      String    // "all-time" | "weekly" | "monthly"
  
  entries     String    // Array of {studentId, name, score, rank, avatarUrl}
  updatedAt   DateTime  @updatedAt
  
  @@unique([type, scopeId, period])
  @@map("leaderboards")
}



// ─── ASSIGNMENTS & QUIZZES ────────────────────────────────────

model Assignment {
  id            String    @id @default(cuid())
  facultyId     String
  faculty       Faculty   @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  classroomId   String
  classroom     Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  
  title         String
  description   String?
  gameSlug      String    // Which game
  chapterNumber Int       // Which chapter to complete
  
  dueDate       DateTime?
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@map("assignments")
}

model QuizAttempt {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  chapterRef  String
  questions   String    // Array of {question, options, chosen, correct}
  score       Int
  maxScore    Int
  
  completedAt DateTime  @default(now())
  
  @@map("quiz_attempts")
}

// ─── ANNOUNCEMENT SYSTEM ────────────────────────────────────

model Announcement {
  id            String    @id @default(cuid())
  
  // NULL means global (SuperAdmin), schoolId means school-wide, classroomId means classroom
  schoolId      String?
  school        School?   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classroomId   String?
  classroom     Classroom? @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  
  createdByUserId String
  createdByRole   String  // "SUPER_ADMIN" | "FACULTY"
  
  title         String
  message       String
  ctaLabel      String?   // Optional button label
  ctaLink       String?   // Optional button link
  
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("announcements")
}

// ─── SCHOOL INVITE CODES ────────────────────────────────────

model InviteCode {
  id            String    @id @default(cuid())
  code          String    @unique
  schoolId      String
  school        School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  role          String    // "FACULTY" | "STUDENT"
  maxUses       Int       @default(50)
  currentUses   Int       @default(0)
  
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  
  @@map("invite_codes")
}

// ─── PARENT NOTIFICATIONS ─────────────────────────────────

model ParentNotification {
  id          String    @id @default(cuid())
  parentId    String
  parent      Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  
  type        String    // achievement_earned, chapter_complete, inactivity_alert, streak_milestone, startup_milestone
  childId     String
  childName   String
  title       String
  message     String
  emoji       String    @default("📢")
  read        Boolean   @default(false)
  data        String?   // JSON payload with extra details
  
  createdAt   DateTime  @default(now())

  @@map("parent_notifications")
}

// ─── AI & ANALYTICS ──────────────────────────────────────────

model AIInteraction {
  id          String    @id @default(cuid())
  studentId   String
  
  type        String
  prompt      String
  response    String
  tokensUsed  Int?
  
  createdAt   DateTime  @default(now())
  
  @@map("ai_interactions")
}


